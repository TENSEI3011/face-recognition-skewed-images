# ─────────────────────────────────────────────────────────────────────
# .env.example — Copy this to .env and fill in your values.
# NEVER commit your actual .env file to git (it is already in .gitignore).
# ─────────────────────────────────────────────────────────────────────

# ── JWT Authentication ────────────────────────────────────────────────
# Required in production.  Generate a strong value with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# If unset, auth_service.py generates a random secret at startup — all
# existing sessions are invalidated on every restart, which is fine for
# local development but breaks production.
JWT_SECRET_KEY=change-this-to-a-random-64-char-hex-string

# ── MongoDB — Choose ONE of the three options below ──────────────────
#
# OPTION A: MongoDB Atlas (cloud — requires internet)
#   Connection string from Atlas → Connect → Drivers → Python.
#   URL-encode special chars: " → %22, @ → %40, # → %23
#MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
#
# OPTION B: Local MongoDB (fully offline / defence deployment) ← RECOMMENDED
#   Install MongoDB Community: https://www.mongodb.com/try/download/community
#   Start:  mongod --dbpath C:\data\db  (Windows)
#   Start:  mongod --dbpath /data/db    (Linux)
MONGO_URI=mongodb://localhost:27017
#
# OPTION C: No MongoDB (local disk fallback)
#   Comment out MONGO_URI entirely. The system stores gallery images as
#   files under data/gallery/. Audit log and watchlist are unavailable.
#MONGO_URI=

# MongoDB database name (default: facerecog_db)
MONGO_DB_NAME=facerecog_db


# ── Runtime environment ───────────────────────────────────────────────
# Set to "production" on Render / Railway to enable production settings.
ENV=development
