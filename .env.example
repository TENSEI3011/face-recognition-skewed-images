# ─────────────────────────────────────────────────────────────────────
# .env.example — Copy this to .env and fill in your values
# NEVER commit your actual .env file to git
# ─────────────────────────────────────────────────────────────────────

# MongoDB Atlas connection string (get from Atlas → Connect → Drivers → Python)
# URL-encode special characters in password: " → %22, @ → %40, # → %23
MONGO_URI=mongodb+srv://facerecog:FACERECOG%222026@facerecognition.phw8q0k.mongodb.net/?retryWrites=true&w=majority&appName=FACERECOGNITION

# MongoDB database name (default: facerecog_db)
MONGO_DB_NAME=facerecog_db

# JWT secret for user authentication (change this to a random string)
SECRET_KEY=change-this-to-a-random-secret-key-in-production

# Set to "production" on Render
ENV=development
